# StreamV2 (MediaMTX) Environment Variables
# Copy this file to .env and fill in your values

# WebRTC: VM external IP — advertised in ICE candidates for NAT traversal
# MUST be the IP of the machine running this container
MTX_WEBRTC_HOST_IP=10.255.32.56

# Stream Mode: "camera" (default) or "test"
STREAM_MODE=camera

# Camera 1 Configuration
CAMERA1_IP=10.255.35.86
CAMERA1_PORT=554
CAMERA1_LOW_PATH=stream2
CAMERA1_HIGH_PATH=stream1
CAMERA1_GATE_ID=gate1

# Camera 2 Configuration
CAMERA2_IP=10.255.35.97
CAMERA2_PORT=554
CAMERA2_LOW_PATH=stream2
CAMERA2_HIGH_PATH=stream1
CAMERA2_GATE_ID=gate2

# Test Video Configuration (used when STREAM_MODE=test)
TEST_VIDEO1_PATH=/videos/test_video1.mp4
TEST_VIDEO2_PATH=/videos/test_video2.mp4

# Host volume path for test videos
TEST_VIDEOS_HOST_PATH=/home/pei_user/streaming_middleware/videos

# V_APP Unified Environment Variables
# Copy this file to .env and fill in your values

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
# This DATABASE_URL is used by the application, ensure it matches above credentials
DATABASE_URL=postgresql://user:password@postgres:5432/database

# --- MongoDB ---
MONGO_URL=mongodb://user:password@mongo:27017
MONGO_HOST=mongo
MONGO_PORT=27017
# These are required for initializing the Mongo container
MONGO_INITDB_ROOT_USERNAME=your_mongo_user
MONGO_INITDB_ROOT_PASSWORD=your_mongo_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO ---
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_secure_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9090

# --- Data Module ---
# RGPD field encryption (AES-256-GCM) — generate with:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=your_base64url_32byte_key_here
DM_API_PREFIX=/api/v1
DECISION_ENGINE_URL=http://decision-engine:8001
# OTEL for DM
OTEL_EXPORTER_OTLP_ENDPOINT=http://10.255.32.132:4317
# Runtime
ENVIRONMENT=development
DEBUG=false
DEBUG_MODE=false
TOKEN_EXPIRY_HOURS=24
# Kafka for decision consumer (uses internal V_APP broker)
KAFKA_BOOTSTRAP=kafka:29092

# --- API Gateway ---
GW_API_PREFIX=/api
# Internal URL for Data Module
DATA_MODULE_URL=http://data-module:8000
# External URLs for video stream (MediaMTX)
STREAM_BASE_URL=http://10.255.32.56:8888
STREAM_WEBRTC_BASE_URL=http://10.255.32.56:8889
KAFKA_BOOTSTRAP_SERVERS=10.255.32.143:9092
KAFKA_DECISION_TOPIC=decision-results-1
KAFKA_CONSUMER_GROUP=api-gateway-decisions
GW_ENV=dev
CORS_ALLOW_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# --- Decision Engine ---
KAFKA_BOOTSTRAP=10.255.32.143:9092
# JSON arrays of gate IDs — Decision Engine handles Entry/Inbound, Infraction Engine handles Highway/Approach
GATE_IDS=["1", "2"]
DECISION_GATE_IDS=["1"]
INFRACTION_GATE_IDS=["2"]
# Internal URL for Data Module API used by Decision Engine
DE_API_URL=http://data-module:8000/api/v1
TIME_TOLERANCE_MINUTES=30

# --- V_Gateway ---
GATEWAY_PORT=8003

# --- V_Brain ---
# V_Brain is gate-agnostic: ONE instance handles all gates
# GATE_IDS must match the same value used by kafka-init
CORRELATOR_TIMEOUT_SECONDS=30

# --- Kafka Configuration ---
# JSON array of gate IDs — used by kafka-init AND v-brain
GATE_IDS=["1","2"]
# External host IP for Kafka advertised listeners
KAFKA_EXTERNAL_HOST=10.255.32.70

# --- Keycloak ---
KC_DB_USER=keycloak
KC_DB_PASSWORD=your_keycloak_db_password
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=intelligent-logistics
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret
DEFAULT_WORKER_PASSWORD=password123
DEFAULT_DRIVER_PASSWORD=driver123

# --- Observability (Promtail) ---
VM_NAME=V_APP
LOKI_URL=10.255.32.132

# --- Data init ---
# demo  = full dataset (historical data, many appointments)
# trial = minimal seed (a truck with a delivery in_transit for live demo flow)
DATA_INIT_SCRIPT=demo

# AI_APP Unified Environment Variables
# Copy this file to .env and fill in your values

# --- Kafka Configuration ---
KAFKA_BOOTSTRAP=<kafka-host>:<kafka-port>

# --- MediaMTX RTSP Streaming Configuration ---
MEDIAMTX_HOST=<mediamtx-host>
MEDIAMTX_PORT=8554

# --- MinIO Object Storage ---
MINIO_HOST=<minio-host>
MINIO_PORT=<minio-port>
MINIO_USER=<minio-access-key>
MINIO_PASSWORD=<minio-secret-key>
MINIO_SECURE=False

# --- AI_Gateway ---
GATEWAY_PORT=8000
GATEWAY_HOST="0.0.0.0"
RECEIVERS=["http://<receiver-host>:<receiver-port>"]

# --- Gate Ids ---
GATE_IDS=["1","2"]

# --- Agents ---
MAX_FRAMES=40
MIN_DETECTION_CONFIDENCE=0.4
FRAMES_BATCH_SIZE=5

# Model download paths
MODELS_PATH_A=/app/AI_APP/agentA/data
MODELS_PATH_B=/app/AI_APP/agentB/data
MODELS_PATH_C=/app/AI_APP/agentC/data

# --- Observability (Promtail) ---
VM_NAME=IA_APP
LOKI_URL=<loki-host>

# --- MLflow Registry (used at build time to download agent models) ---
# Models must be registered in the registry before running docker-compose build
#   AgentA → registry name: truck-detector          (alias: champion)
#   AgentB → registry name: license-plate-detector  (alias: champion)
#   AgentC → registry name: hazard-plate-detector   (alias: champion)
MLFLOW_TRACKING_URI=http://<mlflow-host>:5000
MLFLOW_S3_ENDPOINT_URL=http://<minio-host>:9000
AWS_ACCESS_KEY_ID=<minio-access-key>
AWS_SECRET_ACCESS_KEY=<minio-secret-key>
MODEL_CACHE_DIR=/tmp/model_cache

# AI_APP Unified Environment Variables
# Copy this file to .env and fill in your values

# --- Kafka Configuration ---
KAFKA_BOOTSTRAP=10.255.32.143:9092

# --- Gate Identification ---
GATE_ID=1

# --- NGINX RTMP Streaming Configuration ---
NGINX_RTMP_HOST=10.255.32.80
NGINX_RTMP_PORT=1935

# --- MinIO Object Storage ---
MINIO_HOST=10.255.32.82
MINIO_PORT=9000
ACCESS_KEY=admin
SECRET_KEY=adminadmin

# --- Agent Specific Configs ---
# Buckets for Agent B (LP crops) and C (Hazmat crops)
BUCKET_NAME_LP=lp-crops
BUCKET_NAME_HZ=hz-crops

# Model download paths (used by setup scripts)
MODELS_PATH_A=/app/AI_APP/agentA/data
MODELS_PATH_B=/app/AI_APP/agentB/data
MODELS_PATH_C=/app/AI_APP/agentC/data

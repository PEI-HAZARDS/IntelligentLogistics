# Observability Stack Environment Variables
# Copy to .env and configure

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_changeme

# =============================================================================
# ALERTMANAGER - Gmail SMTP Configuration
# =============================================================================
# For Gmail: Create App Password at https://myaccount.google.com/apppasswords
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=alertas@intelligentlogistics.com
SMTP_AUTH_USERNAME=your-project-email@gmail.com
SMTP_AUTH_PASSWORD=your-app-password-here
ALERT_EMAIL_TO=your-team-email@example.com

# =============================================================================
# ALERTMANAGER - Slack Integration (optional)
# =============================================================================
# Leave SLACK_WEBHOOK_URL empty to disable Slack notifications.
# Create an Incoming Webhook at: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#grafana-alerts

# =============================================================================
# VM IPs
# =============================================================================
# IA_APP VM - Agents, Kafka (IA_Broker), IA_Gateway
IA_APP_IP=
# V_APP VM - V_Broker, V_Gateway, Decision Engine, API Gateway, Data Module, DBs
V_APP_IP=
# MediaMTX VM - Streaming Server (RTSP/WebRTC)
MEDIAMTX_VM_IP=
# Jenkins VM - CI/CD + Observability Stack (Prometheus, Grafana, Loki, Tempo)
JENKINS_VM_IP=
# UI_IL VM - Frontend
UI_IP=
